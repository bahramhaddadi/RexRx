# Shamefully hoist for Angular compatibility
# This ensures packages are hoisted to node_modules root for better Angular CLI compatibility
shamefully-hoist=true

# Strict peer dependencies
# Set to false to avoid issues with Angular's peer dependency structure
strict-peer-dependencies=false

# Auto install peers
auto-install-peers=true

# Use lockfile version 9.0 (pnpm 9+)
lockfile-version=9.0
